# Firebase 프로젝트 설정값
# Firebase 콘솔 → 프로젝트 설정 → 내 앱 → SDK 설정 및 구성에서 복사
# https://console.firebase.google.com/project/onstep-lifeos/settings/general

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── AI 기능 (Stage 7) ───────────────────────────────────────────────────────────
# Google AI Studio → API 키 생성: https://aistudio.google.com/apikey

# 개발 환경용: Next.js API Route (/api/parse-routine)에서 사용
# 주의: NEXT_PUBLIC_ 없음 → 서버에서만 접근, 클라이언트에 절대 노출 안 됨
GEMINI_API_KEY=

# ── 배포 설정 (Stage 8) ──────────────────────────────────────────────────────────
# 프로덕션 빌드 전에 아래 두 값을 설정하세요.
#
# Firebase Function URL (firebase deploy --only functions 후 콘솔에서 확인)
# 예: https://us-central1-onstep-lifeos.cloudfunctions.net/parseRoutine
# 💡 이 값이 설정되면 AI 가져오기가 Firebase Function을 통해 동작합니다
NEXT_PUBLIC_PARSE_API_URL=
